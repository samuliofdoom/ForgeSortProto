; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Forge Sort Proto"
run/main_scene="res://scenes/Main.tscn"
config/features=PackedStringArray("4.6", "Mobile")
config/icon="res://icon.svg"

[autoload]

GameData="*res://scripts/data/GameData.gd"
ScoreManager="*res://scripts/game/ScoreManager.gd"
MetalSource="*res://scripts/game/MetalSource.gd"
OrderManager="*res://scripts/game/OrderManager.gd"
FlowController="*res://scripts/game/FlowController.gd"
MetalFlow="*res://scripts/game/MetalFlow.gd"

[display]

window/size/viewport_width=400
window/size/viewport_height=720
window/stretch/mode="viewport"

[input]

metal_cycle={
"deadzone": 0.5,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":0,"physical_keycode":32,"key_label":0,"unicode":0,"location":0,"echo":false,"script":null)
]
}

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

rendering_device/driver.windows="d3d12"
renderer/rendering_method="mobile"
